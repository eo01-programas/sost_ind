            loginInfoBadge.textContent = `${currentArea} · ${currentUser}`;
        }
        document.getElementById('loginModal').classList.add('hidden');
        logLoginDebug('Login modal hidden; user logged in');

        if (typeof evaluateAdminPrivileges === 'function') {
            try { evaluateAdminPrivileges(); } catch (err) { console.error('evaluateAdminPrivileges', err); }
        }
        try { if (typeof loadIndicatorsList === 'function') loadIndicatorsList(); } catch (err) { console.error('loadIndicatorsList', err); }
        try { loadPeriodYearsForFicha(currentIndicator); } catch (err) { console.error('loadPeriodYearsForFicha', err); }
