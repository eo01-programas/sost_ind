async function loadPeriodYearsForFicha(indicator) {
    const yearInput = document.getElementById('periodYear');
    const yearSelect = document.getElementById('periodYearSelect');
    const yearList = document.getElementById('periodYearList');
    const useSelect = shouldUseYearSelectForFicha() && yearSelect;
    if (yearList) yearList.innerHTML = '';
    if (yearInput) yearInput.placeholder = 'Escriba a\u00f1o';
    if (useSelect) yearSelect.innerHTML = '<option value="">Cargando...</option>';

    if (!currentArea) {
        if (useSelect) yearSelect.innerHTML = '<option value="">Seleccione \u00e1rea</option>';
        if (yearInput) yearInput.placeholder = 'Seleccione \u00e1rea';
        return [];
    }
    try {
        const allPayload = await apiCall('getValidYears', { area: currentArea, complete: 0 });
        const allYears = Array.from(new Set(parseYearEntries(allPayload)))
            .filter(Boolean)
            .map(y => String(y).trim());
        if (!allYears.length) {
            if (useSelect) yearSelect.innerHTML = '<option value="">Sin a\u00f1os disponibles</option>';
            if (yearInput) yearInput.placeholder = 'Sin a\u00f1os disponibles';
            return [];
        }

        const norm = (value) => String(value || "").trim().toLowerCase();
        const checks = await Promise.all(allYears.map(async (year) => {
            const [allIndicators, completeIndicators] = await Promise.all([
                apiCall('getIndicators', { area: currentArea, year }),
                apiCall('getIndicators', { area: currentArea, year, complete: 1 })
            ]);
            const allList = Array.isArray(allIndicators) ? allIndicators : [];
            const completeList = Array.isArray(completeIndicators) ? completeIndicators : [];
            if (!allList.length) return null;
            const completeSet = new Set(completeList.map(norm));
            const incomplete = allList.filter(ind => !completeSet.has(norm(ind)));
            return incomplete.length ? year : null;
        }));

        const filteredYears = checks.filter(Boolean);
        if (!filteredYears.length) {
            if (useSelect) yearSelect.innerHTML = '<option value="">Sin a\u00f1os disponibles</option>';
            if (yearInput) yearInput.placeholder = 'Sin a\u00f1os disponibles';
            return [];
        }
        filteredYears.sort((a, b) => Number(b) - Number(a));
        if (useSelect) {
            yearSelect.innerHTML = '<option value="">-- Seleccionar a\u00f1o --</option>' + filteredYears.map(year => `<option value="${year}">${year}</option>`).join('');
        } else if (yearList) {
            yearList.innerHTML = filteredYears.map(year => `<option value="${year}"></option>`).join('');
        }
        return filteredYears;
    } catch (e) {
        console.error(e);
        if (useSelect) yearSelect.innerHTML = '<option value="">Error al cargar a\u00f1os</option>';
        if (yearInput) yearInput.placeholder = 'Error al cargar a\u00f1os';
        return [];
    }
}
function resolveFichaFrequency(rows) {
    const firstRow = Array.isArray(rows) ? rows.find(r => r) : null;
    let freq = String(firstRow?.FRECUENCIA || '').trim().toUpperCase();
    if (freq) return freq;
    const raw = String(firstRow?.MES_TABLA || '').trim().toUpperCase().replace(/\s+/g, '');
    if (!raw) return 'MENSUAL';
    if (/^(1ER|2DO|3ER|4TO)/.test(raw)) return 'TRIMESTRAL';
    if (/^\d{4}$/.test(raw)) return 'ANUAL';
    return 'MENSUAL';
}

function getFichaYearFromRow(row) {
    const candidates = ['A\u00D1O_TABLA', 'ANO_TABLA', 'A\u00D1O', 'ANO'];
    for (let i = 0; i < candidates.length; i++) {
        const value = row ? row[candidates[i]] : null;
        if (value !== null && value !== undefined && String(value).trim() !== '') {
            return String(value).trim();
        }
    }
    return '';
}

function getFichaYearFromRows(rows) {
    if (!Array.isArray(rows)) return '';
    for (let i = 0; i < rows.length; i++) {
        const year = getFichaYearFromRow(rows[i]);
        if (year) return year;
    }
    return '';
}

function normalizeFichaMonthKey(raw) {
    const up = String(raw || '').trim().toUpperCase();
    if (!up) return '';
    const map = {
        'ENE': 'ENE', 'ENERO': 'ENE',
        'FEB': 'FEB', 'FEBRERO': 'FEB',
        'MAR': 'MAR', 'MARZO': 'MAR',
        'ABR': 'ABR', 'ABRIL': 'ABR',
        'MAY': 'MAY', 'MAYO': 'MAY',
        'JUN': 'JUN', 'JUNIO': 'JUN',
        'JUL': 'JUL', 'JULIO': 'JUL',
        'AGO': 'AGO', 'AGOSTO': 'AGO',
        'SET': 'SET', 'SEPTIEMBRE': 'SET', 'SETIEMBRE': 'SET', 'SEP': 'SET',
        'OCT': 'OCT', 'OCTUBRE': 'OCT',
        'NOV': 'NOV', 'NOVIEMBRE': 'NOV',
        'DIC': 'DIC', 'DICIEMBRE': 'DIC'
    };
    if (map[up]) return map[up];
    const short = up.substring(0, 3);
    if (map[short]) return map[short];
    return short;
}

function normalizeFichaQuarterKey(raw) {
    const up = String(raw || '').trim().toUpperCase().replace(/\s+/g, '');
    if (!up) return '';
    const match = up.match(/^(1ER|2DO|3ER|4TO)/);
    if (match) return match[1];
    return up.substring(0, 3);
}

function normalizeFichaPeriodKey(raw, frequency, row) {
    const freq = String(frequency || '').trim().toUpperCase();
    if (freq === 'TRIMESTRAL') return normalizeFichaQuarterKey(raw);
    if (freq === 'ANUAL') {
        const yearVal = String(raw || getFichaYearFromRow(row) || '').trim();
        return yearVal;
    }
    return normalizeFichaMonthKey(raw);
}

function getFichaExpectedKeys(frequency, rows) {
    const freq = String(frequency || '').trim().toUpperCase();
    if (freq === 'ANUAL') {
        const year = getFichaYearFromRows(rows);
        return year ? [String(year)] : [];
    }
    if (freq === 'TRIMESTRAL') return ['1ER', '2DO', '3ER', '4TO'];
    return baseMonths.map(m => String(m).trim().toUpperCase().substring(0, 3));
}

function hasMissingNumeratorOrDenominator(rows) {
    if (!Array.isArray(rows) || rows.length === 0) return true;
    const frequency = resolveFichaFrequency(rows);
    const expectedKeys = getFichaExpectedKeys(frequency, rows);
    if (!expectedKeys.length) return true;
    const filled = new Set();
    rows.forEach(row => {
        if (!row) return;
        const num = row.NUMERADOR;
        const den = row.DENOMINADOR;
        if (num === null || num === undefined || String(num).trim() === '') return;
        if (den === null || den === undefined || String(den).trim() === '') return;
        const key = normalizeFichaPeriodKey(row.MES_TABLA, frequency, row);
        if (key) filled.add(key);
    });
    return expectedKeys.some(key => !filled.has(key));
}

