const DEBUG_LOGIN = true;
function logLoginDebug(...args) { if (DEBUG_LOGIN && typeof console !== 'undefined') console.log('[LOGIN]', ...args); }
function logLoginWarn(...args) { if (DEBUG_LOGIN && typeof console !== 'undefined') console.warn('[LOGIN]', ...args); }
function logLoginError(...args) { if (DEBUG_LOGIN && typeof console !== 'undefined') console.error('[LOGIN]', ...args); }

function normalizeLoginUserEntry(entry) {
    if (entry === null || entry === undefined) return null;
    if (typeof entry === 'string') {
        const name = entry.trim();
        return name ? { name, role: '' } : null;
    }
    if (typeof entry === 'object') {
        const name = String(entry.USUARIO || entry.usuario || entry.USER || entry.user || entry.NOMBRE || entry.nombre || '').trim();
        if (!name) return null;
        const role = String(entry.ROL || entry.rol || entry.ROLE || entry.role || '').trim();
        return { name, role };
    }
    return null;
}

function isLoginDataValid(data) {
    if (!data || typeof data !== 'object') return false;
    if (data.error) return false;
    const keys = Object.keys(data).filter(k => k && k !== 'error');
    if (!keys.length) return false;
    return keys.some(k => Array.isArray(data[k]) ? data[k].length > 0 : !!data[k]);
}

function setLoginPlaceholders(areaMsg, userMsg) {
    const areaSel = document.getElementById('loginArea');
    if (areaSel) areaSel.innerHTML = `<option value="">${areaMsg}</option>`;
    const userSel = document.getElementById('loginUser');
    if (userSel) userSel.innerHTML = `<option value="">${userMsg}</option>`;
}

function setLoginControlsEnabled(enabled) {
    const areaSel = document.getElementById('loginArea');
    const userSel = document.getElementById('loginUser');
    const submitBtn = document.getElementById('loginSubmit');
    const controls = [areaSel, userSel, submitBtn];
    controls.forEach(ctrl => {
        if (!ctrl) return;
        ctrl.disabled = !enabled;
        ctrl.classList.toggle('opacity-60', !enabled);
        ctrl.classList.toggle('cursor-not-allowed', !enabled);
    });
}

function setLoginStatus(message, isError = false) {
    const status = document.getElementById('loginStatus');
    const retryBtn = document.getElementById('loginRetry');
    if (!status) return;
    if (!message) {
        status.textContent = '';
        status.classList.add('hidden');
        if (retryBtn) retryBtn.classList.add('hidden');
        return;
    }
    status.textContent = message;
    status.classList.remove('hidden');
    status.classList.toggle('text-rose-600', !!isError);
    status.classList.toggle('text-slate-500', !isError);
    if (retryBtn) retryBtn.classList.toggle('hidden', !isError);
}

async function reloadLoginData(force = true) {
    setLoginControlsEnabled(false);
    setLoginPlaceholders('Cargando áreas...', 'Cargando usuarios...');
    setLoginStatus('Cargando áreas y usuarios...', false);
    const freshLoginData = await apiCall('getLoginData', { _force: force });
    if (isLoginDataValid(freshLoginData)) {
        populateLoginUIUser(freshLoginData);
        setLoginStatus('', false);
        setLoginControlsEnabled(true);
        return true;
    }
    const extra = freshLoginData && freshLoginData.error ? ` (${freshLoginData.error})` : '';
    setLoginStatus(`No se pudo cargar áreas/usuarios. Verifica la hoja USUARIOS o la URL del API.${extra}`, true);
    setLoginControlsEnabled(false);
    return false;
}

function getLoginUsersByArea(area) {
    const raw = (loginDataCache && area) ? loginDataCache[area] : null;
    if (!Array.isArray(raw)) return [];
    return raw.map(normalizeLoginUserEntry).filter(Boolean);
}

function populateLoginUsers(area) {
    const userSelect = document.getElementById('loginUser');
    if (!userSelect) return;
    const users = getLoginUsersByArea(area);
    if (!users.length) {
        userSelect.innerHTML = `<option value="">Sin usuarios</option>`;
        logLoginWarn('No users for area', area);
        return;
    }
    userSelect.innerHTML = "";
    users.forEach(u => userSelect.innerHTML += `<option value="${u.name}">${u.name}</option>`);
    logLoginDebug('Users loaded for area', area, users);
}

function resolveSelectedLoginRole(area, user) {
    const match = getLoginUsersByArea(area).find(u => normalizeText(u.name) === normalizeText(user));
    return match ? (match.role || '') : '';
}

