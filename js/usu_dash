    if (isLoginDataValid(cachedLoginData)) {
        loginData = cachedLoginData;
        populateLoginUIUser(loginData);
    }

    // Cargar datos Login desde la API (actualiza si hay nuevo dato)
    const freshLoginData = await apiCall('getLoginData', { _force: !loginData });
