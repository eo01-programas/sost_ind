function handleEditableTableCalculation(target, finalize) {
    if (!target || !target.dataset) return;
    const rowKey = String(target.dataset.row || '').toLowerCase();
    if (rowKey !== 'num' && rowKey !== 'den') return;
    if (isHistoricMode || target.disabled) return;
    const idx = Number(target.dataset.idx);
    if (!Number.isFinite(idx) || idx < 0 || idx >= baseMonths.length) return;

    dataState[rowKey][idx] = String(target.value ?? '').trim();
    recalculateResultForIndex(idx);
    updateResultCellDisplay(idx);
    scheduleChartRefreshFromTable();

    if (finalize) {
        renderTable();
        setFichaEditableState();
        updateChart();

        // --- Guardado automático de datos ---
        const savePayload = {
            area: currentArea,
            indicator: currentIndicator,
            year: currentYear,
            period: baseMonths[idx],
            num: dataState.num[idx],
            den: dataState.den[idx],
            res: dataState.res[idx],
            goal: dataState.goal[idx],
            user: currentUser
        };

        showSaveToast('saving', `Guardando ${baseMonths[idx]}...`);
        apiPost('saveIndicatorData', savePayload).then(res => {
            if (!res || !res.success) {
                console.error('[AutoSave] Error:', res);
                const errMsg = (res && res.error) ? res.error : 'Error desconocido al guardar';
                showSaveToast('error', `Error guardando ${baseMonths[idx]}: ${errMsg}`);
            } else {
                console.log('[AutoSave] Éxito para', baseMonths[idx]);
                showSaveToast('success', `${baseMonths[idx]} guardado correctamente`);
            }
        });

        // --- Auto-prompt SAC si resultado < meta y no hay SAC aún ---
        const sacNeeded = needsSAC(dataState.res[idx], dataState.goal[idx]);
        const currentStatus = sacStatusState[idx];
        if (sacNeeded &&
            currentStatus !== 'submitted' &&
            currentStatus !== 'approved' &&
            currentStatus !== 'pending_entry') {
            showSACPrompt(idx).then(answer => {
                if (answer === 'yes') {
                    openSAC(idx);
                    return;
                }
                createPendingSACBackend(idx);
            });
        }
    }
}

function bindEditableTableCalculation() {
